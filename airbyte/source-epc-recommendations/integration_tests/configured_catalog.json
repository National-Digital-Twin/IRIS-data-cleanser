{
  "streams": [
    {
      "stream": {
        "name": "recommendations",
        "json_schema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "required": ["auth_key", "start_year", "end_year"],
          "properties": {
            "LMK_KEY": { "type": "string" },
            "IMPROVEMENT_ITEM": { "type": "number" },
            "IMPROVEMENT_SUMMARY_TEXT": { "type": ["null", "string"] },
            "IMPROVEMENT_DESCR_TEXT": { "type": ["null", "string"] },
            "IMPROVEMENT_ID": { "type": ["null", "number"] },
            "IMPROVEMENT_ID_TEXT": { "type": ["null", "string"] },
            "INDICATIVE_COST": { "type": ["null", "string"] }
          }
        },
        "supported_sync_modes": ["full_refresh"]
      },
      "sync_mode": "full_refresh",
      "destination_sync_mode": "overwrite"
    }
  ]
}
